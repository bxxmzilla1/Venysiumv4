# Copy to `.env.local` (Vite loads this in development; file is gitignored).
# Production (Vercel): set the same variables in Project Settings → Environment Variables.
# Create credentials at https://my.telegram.org (app type: Web). Add your deploy + dev URLs to allowed origins.
#
# Required for builds off web.telegram.org / webk.telegram.org:
VITE_API_ID=
VITE_API_HASH=
